{
  "name": "context-bridge-mcp",
  "version": "1.1.7",
  "type": "module",
  "description": "Project-scoped shared memory as an MCP stdio server for Claude, Codex, and Gemini. Pluggable JSON/SQLite storage, auto-save hooks, and team attribution.",
  "main": "./dist/server.js",
  "bin": {
    "context-bridge-mcp": "dist/server.js",
    "project-memory-mcp": "dist/server.js"
  },
  "files": [
    "dist/",
    "README.md",
    "docs/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:hooks": "node dist/scripts/test-hooks.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build && npm run test:hooks"
  },
  "keywords": [
    "mcp",
    "memory",
    "claude",
    "codex",
    "gemini",
    "ai",
    "context",
    "model-context-protocol"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Kamlesh-62/llm-context-mcp#readme",
  "bugs": {
    "url": "https://github.com/Kamlesh-62/llm-context-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kamlesh-62/llm-context-mcp.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
